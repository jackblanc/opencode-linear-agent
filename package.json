{
  "name": "linear-opencode-agent",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Self-hosted Linear agent powered by OpenCode and Cloudflare Workers",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "tail": "wrangler tail",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "bun run typecheck && bun run lint:check && bun run format:check",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.6.7",
    "@linear/sdk": "^68.1.0",
    "@opencode-ai/sdk": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^25.0.3",
    "knip": "^5.78.0",
    "oxlint": "^1.35.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.54.0"
  },
  "author": "",
  "license": "MIT"
}
