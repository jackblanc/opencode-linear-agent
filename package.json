{
  "name": "linear-opencode-agent",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --cwd packages/linear-opencode-plugin build",
    "typecheck": "tsc -b packages/handler packages/linear-opencode-plugin",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "bun run typecheck && bun run lint:check && bun run format:check",
    "fix": "bun run lint:fix && bun run format:fix",
    "dev": "bun run --cwd packages/handler dev",
    "deploy": "bun run --cwd packages/handler deploy"
  },
  "devDependencies": {
    "oxlint": "^1.35.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
