{
  "name": "opencode-linear-agent",
  "version": "0.1.3",
  "private": true,
  "description": "Self-hosted Linear agent powered by OpenCode",
  "license": "MIT",
  "author": "",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@linear/sdk": "82.1.0",
      "@opencode-ai/sdk": "1.14.19",
      "@opencode-ai/plugin": "1.14.19",
      "better-result": "2.8.2",
      "xdg-basedir": "5.1.0",
      "zod": "4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "lefthook install || true",
    "start": "bun run --filter @opencode-linear-agent/server start",
    "dev": "bun run --filter @opencode-linear-agent/server dev",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:check": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "knip": "knip",
    "test": "vitest run",
    "check": "bun run typecheck && bun run lint:check && bun run format:check && bun run knip && bun run test",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "devDependencies": {
    "@types/node": "24",
    "knip": "6.5.0",
    "lefthook": "2.1.6",
    "oxfmt": "^0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
