{
  "name": "opencode-linear-agent",
  "version": "0.1.3",
  "type": "module",
  "private": true,
  "description": "Self-hosted Linear agent powered by OpenCode",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@linear/sdk": "^80.1.0",
      "@opencode-ai/sdk": "1.3.13",
      "@opencode-ai/plugin": "1.3.13",
      "better-result": "^2.7.0",
      "xdg-basedir": "^5.1.0",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "prepare": "lefthook install || true",
    "start": "bun run --filter @opencode-linear-agent/server start",
    "dev": "bun run --filter @opencode-linear-agent/server dev",
    "typecheck": "tsc --noEmit",
    "lint:check": "oxlint --report-unused-disable-directives --deny-warnings --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "knip": "knip",
    "check": "bun run typecheck && bun run lint:check && bun run format:check && bun run knip && bun test",
    "fix": "bun run lint:fix && bun run format:fix"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bun-types": "^1.3.11",
    "knip": "^6.3.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.4",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "author": "",
  "license": "MIT"
}
