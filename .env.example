# Server
PORT=3210
PUBLIC_HOSTNAME=your-hostname.example.com

# OpenCode
OPENCODE_URL=http://localhost:4096

# Linear OAuth
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Linear Webhook
LINEAR_WEBHOOK_SECRET=

# Optional: restrict webhooks to one Linear org ID
# LINEAR_ORGANIZATION_ID=

# Optional: comma-separated list of IPs (defaults to Linear's global IPs)
# LINEAR_WEBHOOK_IPS=35.231.147.226,35.243.134.228,34.145.29.68

# Path to directory containing your git repositories
PROJECTS_PATH=~/projects
