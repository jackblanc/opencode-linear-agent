# Docker Compose environment variables

# Required: Anthropic API key for OpenCode
ANTHROPIC_API_KEY=sk-ant-...

# Optional: GitHub token for git operations
GITHUB_TOKEN=ghp_...

# Path to local repository to mount (defaults to ~/projects/reservations)
REPO_PATH=~/projects/reservations

# Tailscale configuration
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# Enable "Reusable" and optionally "Ephemeral"
TS_AUTHKEY=tskey-auth-...

# Tailscale hostname (will be <hostname>.<tailnet>.ts.net)
TAILSCALE_HOSTNAME=linear-agent
