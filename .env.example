# Docker Compose environment variables

# Logging configuration
# LOG_FORMAT: "pretty" (human-readable) or "json" (structured)
# Auto-detects: TTY → pretty, NODE_ENV=production → json, default → json
LOG_FORMAT=pretty

# LOG_LEVEL: DEBUG, INFO, WARN, ERROR (default: INFO)
LOG_LEVEL=INFO

# Required: Anthropic API key for OpenCode (or use Claude Max OAuth)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for git operations and GHCR authentication
# Used for:
# - Git operations (clone, push, etc.)
# - Pulling the opencode image from ghcr.io/jackblanc/environment
# Must have: repo scope + read:packages scope
GITHUB_TOKEN=ghp_...

# Paths to local repositories to mount
# Add one variable per repo, matching config.docker.json keys
REPO_PATH_RESERVATIONS=~/projects/reservations
REPO_PATH_LINEAR_AGENT=~/projects/linear-opencode-agent

# Cloudflare Tunnel configuration
# The tunnel uses config file and credentials from ~/.cloudflared/
# See cloudflare-tunnel-setup.md for setup instructions
# No environment variables needed - config is mounted via volumes in docker-compose.yml

# Note: The opencode service now uses ghcr.io/jackblanc/environment:main-personal-linux
# Before running docker-compose, authenticate with GHCR:
#   echo $GITHUB_TOKEN | docker login ghcr.io -u jackblanc --password-stdin
