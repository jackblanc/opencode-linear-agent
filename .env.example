# Docker Compose environment variables

# Required: Anthropic API key for OpenCode (or use Claude Max OAuth)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for git operations
GITHUB_TOKEN=ghp_...

# Paths to local repositories to mount
# Add one variable per repo, matching config.docker.json keys
REPO_PATH_RESERVATIONS=~/projects/reservations
REPO_PATH_LINEAR_AGENT=~/projects/linear-opencode-agent

# Cloudflare Tunnel configuration
# The tunnel uses config file and credentials from ~/.cloudflared/
# See cloudflare-tunnel-setup.md for setup instructions
# No environment variables needed - config is mounted via volumes in docker-compose.yml

# Optional: Use pre-built Nix sandbox image instead of Dockerfile
# Build with: cd ~/environment && nix build .#sandbox && docker load < result
# OPENCODE_IMAGE=opencode-sandbox:latest
