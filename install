#!/usr/bin/env bash
set -euo pipefail

REPO="jackblanc/opencode-linear-agent"
PLUGIN_PACKAGE="@opencode-linear-agent/plugin"
BIN_NAME="opencode-linear-agent-server"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
XDG_BIN_DIR="${XDG_BIN_DIR:-${HOME}/.local/bin}"
DATA_DIR="${XDG_DATA_HOME}/opencode-linear-agent"
ENV_PATH="${DATA_DIR}/.env"
OPENCODE_CONFIG="${XDG_CONFIG_HOME}/opencode/opencode.json"
INSTALL_DIR="${XDG_BIN_DIR}"
BIN_PATH="${INSTALL_DIR}/${BIN_NAME}"

LAUNCHD_LABEL="com.opencode-linear-agent.server"
LAUNCHD_PLIST="${HOME}/Library/LaunchAgents/${LAUNCHD_LABEL}.plist"
SYSTEMD_UNIT_NAME="opencode-linear-agent.service"
SYSTEMD_UNIT_PATH="${XDG_CONFIG_HOME}/systemd/user/${SYSTEMD_UNIT_NAME}"

VERSION=""
YES="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v|--version)
      VERSION="${2:-}"
      shift 2
      ;;
    -y|--yes)
      YES="true"
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Linear OpenCode Agent runtime setup

Usage:
  install [--version v0.1.0] [--yes]

Options:
  -v, --version   Install server binary from a specific release tag
  -y, --yes       Accept defaults where possible
  -h, --help      Show this help

Install dir priority:
  1) XDG_BIN_DIR
  2) ~/.local/bin (default)
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

prompt() {
  local text="$1"
  local default="${2:-}"
  local value=""
  if [[ "${YES}" == "true" ]]; then
    printf '%s' "${default}"
    return
  fi
  if [[ -n "${default}" ]]; then
    read -r -p "${text} [${default}]: " value
    printf '%s' "${value:-${default}}"
  else
    read -r -p "${text}: " value
    printf '%s' "${value}"
  fi
}

require_value() {
  local key="$1"
  local value="$2"
  if [[ -z "${value}" ]]; then
    echo "Missing required value: ${key}" >&2
    exit 1
  fi
}

detect_suffix() {
  local os
  local arch
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"
  case "${arch}" in
    x86_64) arch="x64" ;;
    arm64|aarch64) arch="arm64" ;;
    *)
      echo "Unsupported arch: ${arch}" >&2
      exit 1
      ;;
  esac
  case "${os}" in
    darwin|linux) ;;
    *)
      echo "Unsupported OS: ${os}" >&2
      exit 1
      ;;
  esac
  printf '%s' "${os}-${arch}"
}

fetch_release_json() {
  if [[ -n "${VERSION}" ]]; then
    local tag="${VERSION}"
    if [[ "${tag}" != v* ]]; then
      tag="v${tag}"
    fi
    curl -fsSL "https://api.github.com/repos/${REPO}/releases/tags/${tag}"
    return
  fi
  curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest"
}

resolve_asset_url() {
  local release_json="$1"
  local asset_name="$2"
  if command -v jq >/dev/null 2>&1; then
    printf '%s' "${release_json}" | jq -r --arg n "${asset_name}" '.assets[] | select(.name==$n) | .browser_download_url' | head -n1
    return
  fi
  printf '%s' "${release_json}" | awk -v n="${asset_name}" '
    $0 ~ "\"name\": \"" n "\"" { hit=1 }
    hit && $0 ~ /browser_download_url/ {
      gsub(/.*"browser_download_url": "/, "");
      gsub(/".*/, "");
      print;
      exit;
    }
  '
}

install_server_binary() {
  local suffix
  local asset_name
  local release_json
  local url
  local tmp

  suffix="$(detect_suffix)"
  asset_name="${BIN_NAME}-${suffix}"
  release_json="$(fetch_release_json)"
  url="$(resolve_asset_url "${release_json}" "${asset_name}")"

  if [[ -z "${url}" || "${url}" == "null" ]]; then
    echo "Could not find release asset ${asset_name}" >&2
    exit 1
  fi

  mkdir -p "${INSTALL_DIR}"
  tmp="$(mktemp)"
  curl -fsSL "${url}" -o "${tmp}"
  install -m 0755 "${tmp}" "${BIN_PATH}"
  rm -f "${tmp}"
  echo "Installed server binary: ${BIN_PATH}"
}

ensure_plugin_config() {
  mkdir -p "$(dirname "${OPENCODE_CONFIG}")"
  if [[ ! -f "${OPENCODE_CONFIG}" ]]; then
    cat > "${OPENCODE_CONFIG}" <<'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": []
}
EOF
  fi

  if command -v jq >/dev/null 2>&1; then
    local tmp
    tmp="$(mktemp)"
    jq --arg plugin "${PLUGIN_PACKAGE}" '.plugin = ((.plugin // []) + [$plugin] | unique)' "${OPENCODE_CONFIG}" > "${tmp}"
    mv "${tmp}" "${OPENCODE_CONFIG}"
  elif command -v python3 >/dev/null 2>&1; then
    python3 - <<PY
import json
from pathlib import Path
cfg = Path("${OPENCODE_CONFIG}")
data = json.loads(cfg.read_text())
plugin = data.get("plugin")
if not isinstance(plugin, list):
    plugin = []
if "${PLUGIN_PACKAGE}" not in plugin:
    plugin.append("${PLUGIN_PACKAGE}")
data["plugin"] = plugin
cfg.write_text(json.dumps(data, indent=2) + "\n")
PY
  else
    echo "Could not edit ${OPENCODE_CONFIG} automatically (need jq or python3)." >&2
    echo "Add this manually: \"plugin\": [\"${PLUGIN_PACKAGE}\"]" >&2
    exit 1
  fi

  echo "Configured OpenCode plugin in: ${OPENCODE_CONFIG}"
}

write_env() {
  mkdir -p "${DATA_DIR}"

  local current_public=""
  local current_client_id=""
  local current_client_secret=""
  local current_webhook_secret=""
  local current_projects=""
  local current_opencode_url="http://localhost:4096"
  local current_port="3210"
  local current_ips=""

  if [[ -f "${ENV_PATH}" ]]; then
    current_public="$(awk -F= '/^PUBLIC_HOSTNAME=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_client_id="$(awk -F= '/^LINEAR_CLIENT_ID=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_client_secret="$(awk -F= '/^LINEAR_CLIENT_SECRET=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_webhook_secret="$(awk -F= '/^LINEAR_WEBHOOK_SECRET=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_projects="$(awk -F= '/^PROJECTS_PATH=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_opencode_url="$(awk -F= '/^OPENCODE_URL=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_port="$(awk -F= '/^PORT=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
    current_ips="$(awk -F= '/^LINEAR_WEBHOOK_IPS=/{print substr($0, index($0, "=")+1)}' "${ENV_PATH}" | tail -n1)"
  fi

  local port
  local public_hostname
  local opencode_url
  local linear_client_id
  local linear_client_secret
  local linear_webhook_secret
  local projects_path
  local webhook_ips

  port="$(prompt "PORT" "${current_port:-3210}")"
  public_hostname="$(prompt "PUBLIC_HOSTNAME" "${current_public}")"
  opencode_url="$(prompt "OPENCODE_URL" "${current_opencode_url:-http://localhost:4096}")"
  linear_client_id="$(prompt "LINEAR_CLIENT_ID" "${current_client_id}")"
  linear_client_secret="$(prompt "LINEAR_CLIENT_SECRET" "${current_client_secret}")"
  linear_webhook_secret="$(prompt "LINEAR_WEBHOOK_SECRET" "${current_webhook_secret}")"
  projects_path="$(prompt "PROJECTS_PATH" "${current_projects:-${HOME}/projects}")"
  webhook_ips="$(prompt "LINEAR_WEBHOOK_IPS (optional, comma-separated)" "${current_ips}")"

  require_value "PUBLIC_HOSTNAME" "${public_hostname}"
  require_value "LINEAR_CLIENT_ID" "${linear_client_id}"
  require_value "LINEAR_CLIENT_SECRET" "${linear_client_secret}"
  require_value "LINEAR_WEBHOOK_SECRET" "${linear_webhook_secret}"
  require_value "PROJECTS_PATH" "${projects_path}"

  {
    printf '# Server\n'
    printf 'PORT=%s\n' "${port}"
    printf 'PUBLIC_HOSTNAME=%s\n\n' "${public_hostname}"
    printf '# OpenCode\n'
    printf 'OPENCODE_URL=%s\n\n' "${opencode_url}"
    printf '# Linear OAuth\n'
    printf 'LINEAR_CLIENT_ID=%s\n' "${linear_client_id}"
    printf 'LINEAR_CLIENT_SECRET=%s\n\n' "${linear_client_secret}"
    printf '# Linear Webhook\n'
    printf 'LINEAR_WEBHOOK_SECRET=%s\n' "${linear_webhook_secret}"
    printf '# Optional: restrict webhooks to one Linear org ID\n'
    printf '# LINEAR_ORGANIZATION_ID=\n\n'
    if [[ -n "${webhook_ips}" ]]; then
      printf 'LINEAR_WEBHOOK_IPS=%s\n\n' "${webhook_ips}"
    else
      printf '# Optional: comma-separated list of IPs\n'
      printf '# LINEAR_WEBHOOK_IPS=35.231.147.226,35.243.134.228,34.145.29.68\n\n'
    fi
    printf '# Path to directory containing your git repositories\n'
    printf 'PROJECTS_PATH=%s\n' "${projects_path}"
  } > "${ENV_PATH}"
  chmod 600 "${ENV_PATH}"

  echo "Wrote env file: ${ENV_PATH}"
}

setup_launchd_service() {
  local desired
  local tmp
  local uid

  mkdir -p "${HOME}/Library/LaunchAgents"

  desired="$(cat <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCHD_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>set -a; source "${ENV_PATH}"; set +a; exec "${BIN_PATH}"</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${DATA_DIR}/launchd.log</string>
  <key>StandardErrorPath</key>
  <string>${DATA_DIR}/launchd.err</string>
</dict>
</plist>
EOF
)"

  if [[ -f "${LAUNCHD_PLIST}" ]]; then
    tmp="$(mktemp)"
    printf '%s\n' "${desired}" > "${tmp}"
    if ! cmp -s "${tmp}" "${LAUNCHD_PLIST}"; then
      rm -f "${tmp}"
      echo "Warning: existing launchd plist differs, skipping: ${LAUNCHD_PLIST}" >&2
      return
    fi
    rm -f "${tmp}"
    uid="$(id -u)"
    launchctl kickstart -k "gui/${uid}/${LAUNCHD_LABEL}" >/dev/null 2>&1 || true
    echo "Launchd service already configured: ${LAUNCHD_LABEL}"
    return
  fi

  printf '%s\n' "${desired}" > "${LAUNCHD_PLIST}"
  uid="$(id -u)"
  launchctl bootstrap "gui/${uid}" "${LAUNCHD_PLIST}" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/${uid}/${LAUNCHD_LABEL}" >/dev/null 2>&1 || true
  echo "Configured launchd service: ${LAUNCHD_LABEL}"
}

setup_systemd_service() {
  local desired
  local tmp

  if ! command -v systemctl >/dev/null 2>&1; then
    echo "systemctl not found, skipping systemd service setup." >&2
    return
  fi

  mkdir -p "$(dirname "${SYSTEMD_UNIT_PATH}")"

  desired="$(cat <<EOF
[Unit]
Description=Linear OpenCode Agent webhook server
After=network.target

[Service]
Type=simple
ExecStart=/bin/bash -lc 'set -a; source "${ENV_PATH}"; set +a; exec "${BIN_PATH}"'
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
EOF
)"

  if [[ -f "${SYSTEMD_UNIT_PATH}" ]]; then
    tmp="$(mktemp)"
    printf '%s\n' "${desired}" > "${tmp}"
    if ! cmp -s "${tmp}" "${SYSTEMD_UNIT_PATH}"; then
      rm -f "${tmp}"
      echo "Warning: existing systemd unit differs, skipping: ${SYSTEMD_UNIT_PATH}" >&2
      return
    fi
    rm -f "${tmp}"
    systemctl --user daemon-reload
    systemctl --user enable --now "${SYSTEMD_UNIT_NAME}" >/dev/null 2>&1 || true
    echo "Systemd service already configured: ${SYSTEMD_UNIT_NAME}"
    return
  fi

  printf '%s\n' "${desired}" > "${SYSTEMD_UNIT_PATH}"
  systemctl --user daemon-reload
  systemctl --user enable --now "${SYSTEMD_UNIT_NAME}" >/dev/null 2>&1 || true
  echo "Configured systemd service: ${SYSTEMD_UNIT_NAME}"
}

setup_background_service() {
  local os
  os="$(uname -s)"
  case "${os}" in
    Darwin)
      setup_launchd_service
      ;;
    Linux)
      setup_systemd_service
      ;;
    *)
      echo "No supported service manager for OS: ${os}" >&2
      ;;
  esac
}

install_server_binary
ensure_plugin_config
write_env
setup_background_service

cat <<EOF

Setup complete.

Run OpenCode:
  opencode serve --port 4096 --hostname 127.0.0.1

Run webhook server:
  ${BIN_PATH}

Env file:
  ${ENV_PATH}

OpenCode config:
  ${OPENCODE_CONFIG}
EOF
