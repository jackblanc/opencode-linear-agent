{
  "name": "@opencode-linear-agent/plugin",
  "version": "0.1.1",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir=dist --target=bun --minify --packages=bundle",
    "dev": "bun build ./src/index.ts --outfile=$HOME/.config/opencode/plugin/linear.js --target=bun --packages=bundle",
    "prepublishOnly": "bun run build && test -f dist/index.js"
  },
  "dependencies": {
    "@linear/sdk": "catalog:",
    "@opencode-ai/plugin": "catalog:",
    "@opencode-ai/sdk": "catalog:",
    "better-result": "catalog:"
  },
  "devDependencies": {
    "@opencode-linear-agent/core": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
