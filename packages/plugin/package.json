{
  "name": "@opencode-linear-agent/plugin",
  "version": "0.1.3",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackblanc/opencode-linear-agent.git"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir=dist --target=bun --minify --packages=bundle",
    "dev": "OUTFILE=\"${XDG_CONFIG_HOME:-$HOME/.config}/opencode/plugin/linear.js\" && mkdir -p \"$(dirname \"$OUTFILE\")\" && bun build ./src/index.ts --outfile=\"$OUTFILE\" --target=bun --packages=bundle",
    "prepublishOnly": "bun run build && test -f dist/index.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@linear/sdk": "catalog:",
    "@opencode-ai/plugin": "catalog:",
    "@opencode-ai/sdk": "catalog:",
    "@opencode-linear-agent/core": "workspace:*",
    "better-result": "catalog:"
  }
}
